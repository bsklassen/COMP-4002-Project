// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

// Clerk manages auth - this model only tracks app-specific user data
model User {
  id             String             @id
  items          UserItem[]
  battleMessages BattleLogMessage[]
  battles        Battle[]
  userSave       UserSave?
}

model Item {
  id    Int        @id @default(autoincrement())
  name  String
  users UserItem[]
}

model UserItem {
  userId String
  itemId Int
  user   User   @relation(fields: [userId], references: [id])
  item   Item   @relation(fields: [itemId], references: [id])
  @@id([userId, itemId])
}

model BattleLogMessage {
  id        Int      @id @default(autoincrement())
  type      String
  text      String
  timestamp DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

model Enemy {
  id                    Int      @id @default(autoincrement())
  name                  String
  imagePath             String
  maxHp                 Int
  atk                   Int
  def                   Int
  basicMultiplier       Float
  basicDamageBonus      Float
  ultimateMultiplier    Float
  ultimateDamageBonus   Float
  order                 Int      @unique
  battles               Battle[]
}

model Battle {
  id          String   @id @default(uuid())
  userId      String
  enemyId     Int
  playerHp    Int
  enemyHp     Int
  activeBuffs Json     @default("[]")
  isComplete  Boolean  @default(false)
  playerWon   Boolean?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  enemy       Enemy    @relation(fields: [enemyId], references: [id])
}

model UserSave {
  id           String @id @default(uuid())
  userId       String @unique
  currentFight Int    @default(1)
  user         User   @relation(fields: [userId], references: [id])
}