// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String             @id @default(uuid())
  username       String             @unique
  email          String             @unique
  password       String
  items          UserItem[]
  battleMessages BattleLogMessage[]
}

model Item {
  id    Int        @id @default(autoincrement())
  name  String
  users UserItem[]
}

// Join table linking users to the items they own
model UserItem {
  userId String
  itemId Int
  user   User   @relation(fields: [userId], references: [id])
  item   Item   @relation(fields: [itemId], references: [id])

  @@id([userId, itemId])
}

model BattleLogMessage {
  id        Int      @id @default(autoincrement())
  type      String   // "system", "ally", or "enemy"
  text      String
  timestamp DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}