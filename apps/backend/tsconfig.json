{
  "extends": "../../tsconfig.base.json",
  "ts-node": {
    "esm": true,
    "experimentalResolver": true,
    "experimentalSpecifierResolution": "node"
  },
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "module": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "typeRoots": [
      "./src/types",
      "../../node_modules/@types"
    ]
  },
  "include": [
    "api/**/*.ts",
    "src/**/*.ts",
    "config/**/*.ts",
    "prisma/**/*.ts"
  ]
}